# DeepSeek (OpenAI-compatible)
# Purpose: script generation LLM provider (when LLM_PROVIDER=deepseek).
# Example:
#   DEEPSEEK_BASE_URL=https://api.deepseek.com
#   DEEPSEEK_MODEL=deepseek-chat
#   DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_MODEL=deepseek-chat

# Doubao TTS (Volcengine)
# Purpose: credentials for both PodcastTTS and single-voice TTS.
# Notes:
# - DOUBAO_ACCESS_KEY is the access token used by the OpenSpeech gateway.
# - DOUBAO_SECRET_KEY is kept for compatibility / future use.
# Examples:
#   DOUBAO_APP_ID=1234567890
#   DOUBAO_ACCESS_KEY=your-access-token
#   DOUBAO_SECRET_KEY=your-secret
#   DOUBAO_REGION=cn-north-1
DOUBAO_APP_ID=replace_me
DOUBAO_ACCESS_KEY=replace_me
DOUBAO_SECRET_KEY=replace_me
DOUBAO_REGION=cn-north-1

# If set to 1, values in .env will override existing process environment variables
# Use case: avoid stale env vars in PowerShell/CI overriding your .env.
# Example: DOTENV_OVERRIDE=1
DOTENV_OVERRIDE=1

# Doubao mode switch:
# - podcast: PodcastTTS (multi-speaker / generative) via wss://.../api/v3/sami/podcasttts (resource volc.service_type.10050)
# - tts_v3_http: Single-voice TTS via https://.../api/v3/tts/unidirectional (official HTTP streaming, requires TTS resource id)
# - tts_v3_ws: Single-voice TTS via wss://.../api/v3/tts/unidirectional/stream (websocket streaming, requires TTS resource id)
# - voiceclone_http: Voice cloning (SpeakerID-based) via https://openspeech.bytedance.com/api/v1/tts (requires X-Api-Key header)
# - tts: alias of tts_v3_http (default single-voice mode)
#
# Optional mode group overlays (auto-loaded by run.py if the file exists):
# - .env.voiceclone_http
# - .env.podcast
# - .env.tts / .env.tts_v3_http / .env.tts_v3_ws
# Examples:
#   DOUBAO_MODE=tts            # TTS2.0 recommended (HTTP)
#   DOUBAO_MODE=tts_v3_ws      # websocket single-voice
#   DOUBAO_MODE=podcast        # podcast multi-speaker
#   DOUBAO_MODE=voiceclone_http
DOUBAO_MODE=tts

# Shared (applies to single-voice modes: tts / tts_v3_http / tts_v3_ws)
# Purpose: default speaker/voice name.
# Notes:
# - Must match the selected TTS resource id (v1 vs v2 voices are not interchangeable).
# - When switching by DOUBAO_TTS_VERSION, it is recommended to set DOUBAO_TTS_V1_VOICE / DOUBAO_TTS_V2_VOICE.
# Example:
#   DOUBAO_TTS_VOICE=...
DOUBAO_TTS_VOICE=

# TTS version switch for HTTP single-voice (default: 1.0)
# Notes:
# - If DOUBAO_TTS_V3_RESOURCE_ID is explicitly set (non-empty), it overrides this switch.
# - Use per-version defaults below when you prefer switching by version.
DOUBAO_TTS_VERSION=1

# Per-version defaults (used when DOUBAO_TTS_V3_RESOURCE_ID is empty)
DOUBAO_TTS_V1_RESOURCE_ID=seed-tts-1.0
DOUBAO_TTS_V2_RESOURCE_ID=seed-tts-2.0

# Optional: per-version voice defaults (used when DOUBAO_TTS_VOICE is empty)
# Examples (fill with voices you have enabled in your console):
#   DOUBAO_TTS_V1_VOICE=...
#   DOUBAO_TTS_V2_VOICE=...
DOUBAO_TTS_V1_VOICE=
DOUBAO_TTS_V2_VOICE=

# Debug switches
# If set to 1, do not fallback to local SAPI when Doubao TTS fails (fail fast)
# Example:
#   DOUBAO_TTS_DISABLE_FALLBACK=1
DOUBAO_TTS_DISABLE_FALLBACK=0

# If set to 1, rerun TTS even if episode is already tts_done / audio file exists
# Example:
#   DOUBAO_TTS_FORCE=1
DOUBAO_TTS_FORCE=0

# =============================
# MODE BLOCK (mutually exclusive)
# Only ONE of the following blocks should be enabled at a time.
# =============================

# [MODE=tts / tts_v3_http] Single-voice TTS via official HTTP streaming (recommended)
# Purpose: HTTP unidirectional streaming endpoint.
DOUBAO_TTS_V3_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
# X-Api-Resource-Id (must match your speaker type)
# Notes:
# - If set (non-empty), DOUBAO_TTS_V3_RESOURCE_ID overrides the DOUBAO_TTS_VERSION switch.
# - If empty, the project will choose resource_id by DOUBAO_TTS_VERSION (default 1.0).
# Resource ID examples:
# - seed-tts-1.0 / volc.service_type.10029 (字符版)
# - seed-tts-1.0-concurr / volc.service_type.10048 (并发版)
# - seed-tts-2.0 (TTS 2.0 字符版)
# Example:
#   DOUBAO_TTS_V3_RESOURCE_ID=seed-tts-2.0
DOUBAO_TTS_V3_RESOURCE_ID=
# Optional: model version (e.g. seed-tts-1.1). Leave empty to use default.
# Example:
#   DOUBAO_TTS_V3_MODEL=seed-tts-1.1
DOUBAO_TTS_V3_MODEL=
# If set to 1, treat input as SSML (when the input contains <speak>...</speak> etc)
# Official notes:
# - Choose text_type=ssml
# - All content must be wrapped by a single <speak> root element
# - Bidirectional streaming API does NOT support SSML
# - <break> only works for TTS model 1.0 voices, NOT for TTS 2.0 voices (e.g. seed-tts-2.0)
# Example:
#   DOUBAO_TTS_V3_FORCE_SSML=1
DOUBAO_TTS_V3_FORCE_SSML=1

# SSML text_type (official requirement: text_type=ssml)
# Must be the string "ssml" (do NOT use numeric enums).
# Example:
#   DOUBAO_TTS_V3_TEXT_TYPE_SSML=ssml
DOUBAO_TTS_V3_TEXT_TYPE_SSML=ssml

# If set to 1, send SSML in the dedicated req_params.ssml field.
# Notes:
# - Recommended for TTS 1.0 when you want SSML tags to be interpreted (not spoken).
# - For TTS 2.0, SSML is not fully supported; keep this off unless you know your gateway accepts it.
DOUBAO_TTS_V3_SEND_SSML_FIELD=

# SSML length recommendation (including tags). Per doc, >150 chars increases badcase probability.
# - SSML_MAX_CHARS: warn when exceeded (default 150)
# - SSML_STRICT: if set to 1, raise error when exceeded
DOUBAO_TTS_V3_SSML_MAX_CHARS=150
DOUBAO_TTS_V3_SSML_STRICT=0

# If set to 1, allow unsupported SSML tags to be stripped best-effort.
# Example use case: you are using seed-tts-2.0 but your SSML contains <break>, which is not supported.
DOUBAO_TTS_V3_ALLOW_UNSUPPORTED_SSML=0

# Optional: override request namespace.
# Notes:
# - Leave empty by default.
# - Do NOT set to BidirectionalTTS when you need SSML (official: bidirectional does not support SSML).
DOUBAO_TTS_V3_NAMESPACE=
# TTS2.0 style controls (only some speakers support emotion)
# Examples:
#   DOUBAO_TTS_V3_EMOTION=happy
#   DOUBAO_TTS_V3_EMOTION_SCALE=4   # range 1~5
DOUBAO_TTS_V3_EMOTION=
DOUBAO_TTS_V3_EMOTION_SCALE=
# TTS2.0 conversational style hint (only first entry is effective per doc)
# Priority:
# - If DOUBAO_TTS_V3_CONTEXT_TEXT is set (non-empty), it is used.
# - Otherwise DOUBAO_TTS_V3_CONTEXT_TEXTS is parsed and the FIRST item is used.
# Examples:
#   DOUBAO_TTS_V3_CONTEXT_TEXT=你的语气更欢乐一点，像播客主播一样自然
#   DOUBAO_TTS_V3_CONTEXT_TEXTS=["你可以用特别特别痛心的语气说话吗?"]
#   DOUBAO_TTS_V3_CONTEXT_TEXTS=你嗓门再小点,第二条不会生效
DOUBAO_TTS_V3_CONTEXT_TEXT=
DOUBAO_TTS_V3_CONTEXT_TEXTS=

# [MODE=voiceclone_http] Voice cloning TTS via HTTP (SpeakerID as voice_type)
# Notes:
# - Uses https://openspeech.bytedance.com/api/v1/tts and header "X-Api-Key" ("x-api-key" is also sent for compatibility).
# - voice_type must be your trained SpeakerID (starts with "S_").
# - By default this mode strips SSML tags (since some cloned models do not support ssml).
# - If you see server error code=3031 (RPC timeout), reduce DOUBAO_VOICECLONE_MAX_BYTES and/or switch cluster to volcano_icl_concurr.
# Examples:
#   DOUBAO_VOICECLONE_API_KEY=replace_me
#   DOUBAO_VOICECLONE_SPEAKER_ID=S_xxxx
#   DOUBAO_VOICECLONE_CLUSTER=volcano_icl
DOUBAO_VOICECLONE_URL=https://openspeech.bytedance.com/api/v1/tts
DOUBAO_VOICECLONE_API_KEY=replace_me
DOUBAO_VOICECLONE_SPEAKER_ID=
DOUBAO_VOICECLONE_CLUSTER=volcano_icl
DOUBAO_VOICECLONE_UID=auto_podcast
DOUBAO_VOICECLONE_ENCODING=mp3
DOUBAO_VOICECLONE_SPEED_RATIO=0.95
DOUBAO_VOICECLONE_RATE=24000
DOUBAO_VOICECLONE_LOUDNESS_RATIO=
DOUBAO_VOICECLONE_EXPLICIT_LANGUAGE=zh
DOUBAO_VOICECLONE_CONTEXT_LANGUAGE=
# If set to 1, strip SSML tags before sending (default: 1)
DOUBAO_VOICECLONE_STRIP_SSML=1
# If set to 1, enable sentence split (helps mitigate ICL1.0 speaking too fast)
DOUBAO_VOICECLONE_SPLIT_SENTENCE=1
# Request extra_param (jsonstring). Example: {"mute_cut_threshold":"400", "mute_cut_remain_ms":"100"}
DOUBAO_VOICECLONE_EXTRA_PARAM=
# Chunking / retry tuning (to mitigate server RPC timeout code=3031)
DOUBAO_VOICECLONE_MAX_BYTES=300
DOUBAO_VOICECLONE_MIN_BYTES=80
DOUBAO_VOICECLONE_RETRIES=1
DOUBAO_VOICECLONE_RETRY_BACKOFF_SECONDS=1.0

# [MODE=tts_v3_ws] Single-voice TTS via websocket streaming
# Uncomment this block when DOUBAO_MODE=tts_v3_ws.
#DOUBAO_TTS_V3_WS_URL=wss://openspeech.bytedance.com/api/v3/tts/unidirectional/stream
#DOUBAO_TTS_V3_RESOURCE_ID=seed-tts-2.0
#DOUBAO_TTS_V3_WS_APP_KEY=aGjiRDfUWi

# [MODE=podcast] PodcastTTS via websocket (multi-speaker)
# Uncomment this block when DOUBAO_MODE=podcast.
# Notes:
# - DOUBAO_RESOURCE_ID must be the podcast resource: volc.service_type.10050
#DOUBAO_WS_URL=wss://openspeech.bytedance.com/api/v3/sami/podcasttts
#DOUBAO_RESOURCE_ID=volc.service_type.10050
#DOUBAO_WS_APP_KEY=aGjiRDfUWi
#DOUBAO_WS_SEQUENCE=1

# General
# Purpose: overall HTTP timeout for external API calls (LLM/TTS/etc).
# Example:
#   HTTP_TIMEOUT_SECONDS=180
HTTP_TIMEOUT_SECONDS=180

# Paths (optional overrides)
# Purpose: keep DB path stable (not per-run). If you move it, you lose historical state.
# Example:
#   PODCAST_DB_PATH=./out/podcast.sqlite
PODCAST_DB_PATH=./out/podcast.sqlite

# LLM provider selection: moonshot or deepseek.
# Example:
#   LLM_PROVIDER=moonshot
LLM_PROVIDER=moonshot
# Moonshot (when LLM_PROVIDER=moonshot)
# Example:
#   MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
#   MOONSHOT_MODEL=kimi-k2-0905-preview
#   MOONSHOT_API_KEY=sk-...
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2-0905-preview
MOONSHOT_API_KEY=replace_me

# Research provider selection: metaso or anspire
# Purpose: choose which research provider to use for web research.
# Example:
#   RESEARCH_PROVIDER=metaso
#   RESEARCH_PROVIDER=anspire
RESEARCH_PROVIDER=metaso

# Metaso research (optional)
# Purpose: enable web research in fetch step.
# Example:
#   METASO_API_KEY=mk-...
#   METASO_MODEL=fast
METASO_API_KEY=replace_me
METASO_MODEL=fast

# Anspire research (optional)
# Purpose: alternative web research provider using Anspire Search Agent API.
# Notes:
# - Get your API key from https://open.anspire.cn/
# - top_k: number of search results to return (default: 5)
# - is_stream: use streaming output (true) or JSON format (false, default)
# Example:
#   ANSPIRE_API_KEY=your-api-key
#   ANSPIRE_TOP_K=5
#   ANSPIRE_IS_STREAM=false
ANSPIRE_API_KEY=replace_me
ANSPIRE_TOP_K=5
ANSPIRE_IS_STREAM=false
ANSPIRE_TIMEOUT_SECONDS=60
ANSPIRE_MAX_ITEMS=
ANSPIRE_MAX_RETRIES=3
ANSPIRE_RETRY_DELAY=1.0
