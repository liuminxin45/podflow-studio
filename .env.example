# Auto-Podcast Studio — Environment Variables
# Copy this file to .env and fill in your values.
# All values can also be configured in the app's Settings page.

# ── LLM (OpenAI-compatible) ──────────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

