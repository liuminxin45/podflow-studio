# =============================
# Source: .env.tts
# =============================
# =============================
# Single-Voice TTS Mode Config
# Auto-loaded when DOUBAO_MODE=tts or tts_v3_http
# =============================

# TTS HTTP endpoint
DOUBAO_TTS_V3_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional

# Version switch (1 for TTS1.0, 2 for TTS2.0)
DOUBAO_TTS_VERSION=1

# Per-version resource IDs
DOUBAO_TTS_V1_RESOURCE_ID=seed-tts-1.0
DOUBAO_TTS_V2_RESOURCE_ID=seed-tts-2.0

# Override resource ID (leave empty to use version-based selection)
DOUBAO_TTS_V3_RESOURCE_ID=

# Voice selection (leave empty to use per-version defaults)
DOUBAO_TTS_VOICE=

# Per-version voice defaults (fill with your enabled voices)
DOUBAO_TTS_V1_VOICE=
DOUBAO_TTS_V2_VOICE=

# SSML support
DOUBAO_TTS_V3_FORCE_SSML=1
DOUBAO_TTS_V3_TEXT_TYPE_SSML=ssml
DOUBAO_TTS_V3_SEND_SSML_FIELD=
DOUBAO_TTS_V3_SSML_MAX_CHARS=150
DOUBAO_TTS_V3_SSML_STRICT=0
DOUBAO_TTS_V3_ALLOW_UNSUPPORTED_SSML=0

# TTS2.0 style controls (only for supported speakers)
DOUBAO_TTS_V3_EMOTION=
DOUBAO_TTS_V3_EMOTION_SCALE=
DOUBAO_TTS_V3_CONTEXT_TEXT=
DOUBAO_TTS_V3_CONTEXT_TEXTS=

# Optional overrides
DOUBAO_TTS_V3_MODEL=
DOUBAO_TTS_V3_NAMESPACE=

