# Prefer values in this .env over any existing process environment variables
DOTENV_OVERRIDE=1

# =============================
# Doubao TTS Mode Switch
# Change this ONE line to switch TTS modes:
# - voiceclone_http  → Voice cloning (SpeakerID)
# - tts / tts_v3_http → Single-voice TTS (HTTP)
# - tts_v3_ws        → Single-voice TTS (WebSocket)
# - podcast          → Multi-speaker PodcastTTS
#
# Mode-specific configs are auto-loaded from:
# - .env.voiceclone_http
# - .env.tts
# - .env.tts_v3_ws
# - .env.podcast
# =============================
DOUBAO_MODE=tts

# Shared settings (apply to all modes)
DOUBAO_TTS_VOICE=zh_female_vv_uranus_bigtts
DOUBAO_TTS_DISABLE_FALLBACK=0
DOUBAO_TTS_FORCE=0

# General
HTTP_TIMEOUT_SECONDS=180

# Paths (optional overrides)
PODCAST_DB_PATH=./out/podcast.sqlite
LLM_PROVIDER=deepseek
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2-0905-preview
MOONSHOT_API_KEY=sk-7I3yv5XBtRUG9R9KoYordU1mDfVJBD0HZ5LmE6T0ev1hGqsR


# Research provider selection: metaso or anspire
RESEARCH_PROVIDER=anspire

# Metaso research (optional)
METASO_API_KEY=mk-ED73D964A6996ADE50A1ACDD47356BA8
METASO_MODEL=fast
METASO_MAX_ITEMS=10

# Anspire research (optional)
ANSPIRE_API_KEY=sk-ue3OHcH7XllzCRHpo87k9n5QhGh7H0RB
ANSPIRE_TOP_K=5
ANSPIRE_IS_STREAM=false
ANSPIRE_TIMEOUT_SECONDS=60
ANSPIRE_MAX_ITEMS=1
ANSPIRE_MAX_RETRIES=3
ANSPIRE_RETRY_DELAY=1.0

# =============================
# TTS Mode Configurations
# These are loaded automatically based on DOUBAO_MODE
# =============================

# Voice Clone Config (when DOUBAO_MODE=voiceclone_http)
DOUBAO_VOICECLONE_API_KEY=dc159349-9fab-43b9-8812-0bacd403833a
DOUBAO_VOICECLONE_SPEAKER_ID=S_yiQKtNFN1

# Podcast TTS Mode (when DOUBAO_MODE=podcast)
DOUBAO_PODCAST_WS_URL=wss://openspeech.bytedance.com/api/v3/sami/podcasttts
DOUBAO_PODCAST_RESOURCE_ID=volc.service_type.10050

# Single-Voice TTS Mode (when DOUBAO_MODE=tts or tts_v3_http)
DOUBAO_TTS_V3_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
DOUBAO_TTS_VERSION=2
DOUBAO_TTS_V3_RESOURCE_ID=seed-tts-2.0

# TTS稳定性参数配置
DOUBAO_TTS_V3_UID=auto_podcast
DOUBAO_TTS_V3_FORMAT=mp3
DOUBAO_TTS_V3_SAMPLE_RATE=24000
DOUBAO_TTS_V3_SPEECH_RATE=-5
DOUBAO_TTS_V3_EMOTION_SCALE=4
DOUBAO_PODCAST_FORMAT=mp3
DOUBAO_PODCAST_SAMPLE_RATE=24000
DOUBAO_PODCAST_SPEECH_RATE=-5

# TTS呼吸感和停顿配置
DOUBAO_TTS_V3_SILENCE_DURATION=800

# TTS 2.0 语音风格控制
# 平稳专业风格
DOUBAO_TTS_V3_CONTEXT_TEXTS=["请用温和亲切的语气说话"]
# 温和亲切风格  
#DOUBAO_TTS_V3_CONTEXT_TEXTS=["请用温和亲切的语气说话"]
# 活泼开朗风格
#DOUBAO_TTS_V3_CONTEXT_TEXTS=["请用活泼开朗的语气说话"]

